# Required: Telegram bot token from @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456789

# Recommended: Comma-separated Telegram user IDs allowed to use the bot.
# Get your ID by messaging @userinfobot on Telegram.
# Leave empty to allow all users (not recommended).
ALLOWED_USERS=123456789

# Optional: Path to claude CLI binary (default: claude)
# CLAUDE_BIN=claude

# Optional: Session timeout in seconds (default: 1800 = 30 min)
# SESSION_TIMEOUT=1800

# Optional: Default timezone for heartbeat schedules (default: America/New_York)
# HEARTBEAT_TIMEZONE=Europe/London
